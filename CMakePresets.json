{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ci-debug-linux",
      "displayName": "CI Debug Linux",
      "binaryDir": "${sourceDir}/build/ci-debug-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MICRODB_MANAGED_STRESS_SMOKE_MAX_MS": "3000",
        "MICRODB_MANAGED_STRESS_LONG_MAX_MS": "12000",
        "MICRODB_FS_MATRIX_SMOKE_MAX_MS": "3500",
        "MICRODB_FS_MATRIX_LONG_MAX_MS": "15000"
      }
    },
    {
      "name": "ci-debug-windows",
      "displayName": "CI Debug Windows",
      "binaryDir": "${sourceDir}/build/ci-debug-windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MICRODB_MANAGED_STRESS_SMOKE_MAX_MS": "5000",
        "MICRODB_MANAGED_STRESS_LONG_MAX_MS": "20000",
        "MICRODB_FS_MATRIX_SMOKE_MAX_MS": "6000",
        "MICRODB_FS_MATRIX_LONG_MAX_MS": "25000"
      }
    },
    {
      "name": "release-linux",
      "displayName": "Release Linux",
      "binaryDir": "${sourceDir}/build/release-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MICRODB_BUILD_TESTS": "ON",
        "MICRODB_MANAGED_STRESS_SMOKE_MAX_MS": "4000",
        "MICRODB_MANAGED_STRESS_LONG_MAX_MS": "16000",
        "MICRODB_FS_MATRIX_SMOKE_MAX_MS": "5000",
        "MICRODB_FS_MATRIX_LONG_MAX_MS": "18000"
      }
    },
    {
      "name": "release-windows",
      "displayName": "Release Windows",
      "binaryDir": "${sourceDir}/build/release-windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MICRODB_BUILD_TESTS": "ON",
        "MICRODB_MANAGED_STRESS_SMOKE_MAX_MS": "7000",
        "MICRODB_MANAGED_STRESS_LONG_MAX_MS": "25000",
        "MICRODB_FS_MATRIX_SMOKE_MAX_MS": "8000",
        "MICRODB_FS_MATRIX_LONG_MAX_MS": "28000"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ci-debug-linux",
      "configurePreset": "ci-debug-linux",
      "configuration": "Debug"
    },
    {
      "name": "ci-debug-windows",
      "configurePreset": "ci-debug-windows",
      "configuration": "Debug"
    },
    {
      "name": "release-linux",
      "configurePreset": "release-linux",
      "configuration": "Release"
    },
    {
      "name": "release-windows",
      "configurePreset": "release-windows",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "ci-debug-linux",
      "configurePreset": "ci-debug-linux",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-debug-windows",
      "configurePreset": "ci-debug-windows",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-linux",
      "configurePreset": "release-linux",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-windows",
      "configurePreset": "release-windows",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
