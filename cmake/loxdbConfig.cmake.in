@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/loxdbTargets.cmake")

if(TARGET loxdb::loxdb)
    set(_loxdb_imported_location
        "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/${CMAKE_STATIC_LIBRARY_PREFIX}loxdb${CMAKE_STATIC_LIBRARY_SUFFIX}"
    )
    set_target_properties(loxdb::loxdb PROPERTIES
        IMPORTED_LOCATION "${_loxdb_imported_location}"
        IMPORTED_LOCATION_RELEASE "${_loxdb_imported_location}"
        IMPORTED_LOCATION_NOCONFIG "${_loxdb_imported_location}"
        IMPORTED_LOCATION_DEBUG "${_loxdb_imported_location}"
        IMPORTED_LOCATION_RELWITHDEBINFO "${_loxdb_imported_location}"
        IMPORTED_LOCATION_MINSIZEREL "${_loxdb_imported_location}"
    )
endif()

check_required_components(loxdb)

