@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/loxdbTargets.cmake")

if(TARGET loxdb::loxdb)
    get_target_property(_loxdb_release_location loxdb::loxdb IMPORTED_LOCATION_RELEASE)
    if(_loxdb_release_location)
        set_target_properties(loxdb::loxdb PROPERTIES
            IMPORTED_LOCATION "${_loxdb_release_location}"
            IMPORTED_LOCATION_DEBUG "${_loxdb_release_location}"
            IMPORTED_LOCATION_RELWITHDEBINFO "${_loxdb_release_location}"
            IMPORTED_LOCATION_MINSIZEREL "${_loxdb_release_location}"
            IMPORTED_LOCATION_NOCONFIG "${_loxdb_release_location}"
            MAP_IMPORTED_CONFIG_DEBUG Release
            MAP_IMPORTED_CONFIG_RELWITHDEBINFO Release
            MAP_IMPORTED_CONFIG_MINSIZEREL Release
            MAP_IMPORTED_CONFIG_NOCONFIG Release
        )
    endif()
endif()

check_required_components(loxdb)

