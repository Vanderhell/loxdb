@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/loxdbTargets.cmake")

if(TARGET loxdb::loxdb)
    foreach(_loxdb_location_property
            IMPORTED_LOCATION_RELEASE
            IMPORTED_LOCATION_NOCONFIG
            IMPORTED_LOCATION_DEBUG
            IMPORTED_LOCATION_RELWITHDEBINFO
            IMPORTED_LOCATION_MINSIZEREL)
        get_target_property(_loxdb_location loxdb::loxdb "${_loxdb_location_property}")
        if(_loxdb_location)
            set_target_properties(loxdb::loxdb PROPERTIES
                IMPORTED_LOCATION "${_loxdb_location}"
            )
            break()
        endif()
    endforeach()
endif()

check_required_components(loxdb)

